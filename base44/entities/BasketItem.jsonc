{
  "name": "BasketItem",
  "type": "object",
  "properties": {
    "item_id": {
      "type": "string",
      "description": "ID of the ClothingItem"
    },
    "item_name": {
      "type": "string",
      "description": "Display name of the clothing item"
    },
    "item_category": {
      "type": "string",
      "description": "Category of the clothing item"
    },
    "item_image_url": {
      "type": "string",
      "description": "Optional photo URL"
    },
    "description": {
      "type": "string",
      "description": "Optional description or notes for this basket item (up to 1000 characters)"
    },
    "status": {
      "type": "string",
      "enum": [
        "in_basket",
        "in_load",
        "removed"
      ],
      "default": "in_basket",
      "description": "Current status of this basket entry"
    }
  },
  "required": [
    "item_name",
    "status"
  ]
}